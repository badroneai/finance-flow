{
  "name": "finance-flow-public",
  "version": "1.0.0",
  "description": "نسخة Static تعمل على GitHub Pages (بدون باك-إند) لإدارة التدفقات المالية والعمولات بشكل بسيط.",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "npx eslint src/",
    "format": "npx prettier --write src/",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/badroneai/finance-flow.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/badroneai/finance-flow/issues"
  },
  "homepage": "https://github.com/badroneai/finance-flow#readme",
  "engines": {
    "node": ">=20.19.0"
  },
  "lint-staged": {
    "src/**/*.{js,jsx}": [
      "prettier --write",
      "eslint --max-warnings=0 --no-warn-ignored"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@rollup/rollup-linux-arm64-gnu": "^4.60.0",
    "@supabase/supabase-js": "^2.99.2",
    "dompurify": "^3.3.3",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.0"
  }
}
